generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // ajuste se estiver usando outro banco
  url      = env("DATABASE_URL")
}

model Cuidador {
  id        Int      @id @default(autoincrement())
  nome      String
  chavePix  String?

  escalas   Escala[]

  createdAt DateTime @default(now())
}

model Contrato {
  id              Int      @id @default(autoincrement())

  // Dados do assistido
  nomeAssistido   String
  documento       String?

  // Endereço
  endereco        String
  numero          String
  complemento     String?
  bairro          String
  cidade          String
  estado          String
  cep             String

  // Controle
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())

  escalas         Escala[]
}

model Escala {
  id           Int      @id @default(autoincrement())

  cuidadorId   Int
  contratoId   Int

  data         DateTime
  horas        Float
  valorHora    Float

  cuidador     Cuidador @relation(fields: [cuidadorId], references: [id])
  contrato     Contrato @relation(fields: [contratoId], references: [id])

  createdAt    DateTime @default(now())

  @@index([cuidadorId])
  @@index([contratoId])
}
