generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // ajuste se estiver usando outro banco
  url      = env("DATABASE_URL")
}

model Cuidador {
  id        Int      @id @default(autoincrement())
  nome      String
  cpf       String
  telefone  String?
  pix       String?
  createdAt DateTime @default(now())
}

model Contratante {
  id        Int      @id @default(autoincrement())
  nome      String
  cpf       String
  telefone  String?
  email     String?
  endereco  String?
  createdAt DateTime @default(now())

  contratos Contrato[]
}

model Contrato {
  id              Int      @id @default(autoincrement())

  contratanteId   Int
  contratante     Contratante @relation(fields: [contratanteId], references: [id])

  // ===== ASSISTIDO =====
  nomeAssistido   String
  documento       String?

  // ===== ENDEREÇO =====
  endereco        String
  numero          String
  complemento     String?
  bairro          String
  cidade          String
  estado          String
  cep             String

  // ===== CONTROLE =====
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())

  escalas         Escala[]
}

model Escala {
  id           Int      @id @default(autoincrement())

  cuidadorId   Int
  contratoId   Int

  data         DateTime
  horas        Float
  valorHora    Float

  cuidador     Cuidador @relation(fields: [cuidadorId], references: [id])
  contrato     Contrato @relation(fields: [contratoId], references: [id])

  createdAt    DateTime @default(now())

  @@index([cuidadorId])
  @@index([contratoId])
}
